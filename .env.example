# Backend API URL (server-side only, never exposed to browser)
# Can be set at runtime when starting the server
NUXT_BACKEND_URL=http://localhost:8888

# First-party OAuth client id for BFF login (must match a registered oauth2_clients row)
# NUXT_OAUTH_ADMIN_CLIENT_ID=cadence-admin-ui

# --- OAuth2 BFF (first-party browser → Nuxt only) ---
# Register redirect URIs that point at this Nuxt origin, e.g. http://localhost:3000/
# Authorization code flow without exposing the API hostname to the browser:
#   GET {this origin}/api/oauth/authorize-proxy?response_type=code&client_id=...&redirect_uri=...&...
# Nuxt server forwards to Cadence GET /oauth2/authorize and returns the Location (consent or error).
# Consent page: /oauth/consent — context/decision proxied via /api/oauth2/consent/*
# API must redirect consent to this app: set CADENCE_CONSENT_UI_URL or CADENCE_OAUTH_REDIRECT_BASE_URL
# on the Cadence API (see repo root .env.example).

# App branding (build-time, for custom deployments)
NUXT_PUBLIC_APP_NAME=Cadence
NUXT_PUBLIC_APP_TAGLINE=AI Orchestration Platform

# App version shown in the UI footer.
# Defaults to package.json version if not set.
NUXT_PUBLIC_APP_VERSION=2.0.2

# Git commit hash shown in the UI footer.
# Defaults to `git rev-parse --short HEAD` at build time if not set.
# In production, set this via CI/CD (see scripts/bash/write-version.sh).
NUXT_PUBLIC_GIT_HASH=
